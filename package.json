{
  "name": "metis-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "bootstrap": "bash scripts/bootstrap.sh",
    "env:check": "tsx scripts/env-check.ts",
    "context:check": "bash scripts/context-check.sh",
    "integration:reset:preflight": "tsx scripts/integration-reset-preflight.ts",
    "e2e:guard": "tsx scripts/e2e-guard.ts",
    "e2e:coverage:check": "tsx scripts/e2e-coverage-check.ts",
    "e2e:readonly": "tsx scripts/e2e-readonly.ts",
    "integration:fixtures:plan": "tsx scripts/integration-fixture-reset.ts",
    "integration:fixtures:reset": "tsx scripts/integration-fixture-reset.ts --execute",
    "integration:full-reset:plan": "tsx scripts/integration-full-reset.ts",
    "integration:full-reset": "tsx scripts/integration-full-reset.ts --execute",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@clerk/nextjs": "^7.4.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "d3-geo": "^3.1.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "svix": "^1.95.2",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "prisma": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/topojson-client": "^3.1.5",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
