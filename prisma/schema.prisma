// ============================================================
// Metis Platform — Prisma Schema  v1.0
// Phase 1: Core entities + Tax Lien module
// Import path: import { PrismaClient } from "@/generated/prisma"
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TENANT AND USERS
// ============================================================

model Tenant {
  id                       String    @id @default(cuid())
  clerkOrgId               String    @unique
  name                     String
  slug                     String    @unique
  plan                     PlanTier  @default(STARTER)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripeSubscriptionStatus String? // active, trialing, past_due, canceled, etc.
  trialEndsAt              DateTime?
  currentPeriodEnd         DateTime?
  adminNotes               String?
  anthropicApiKey          String? // BYOK: tenant-supplied, never platform key
  fixtureSet               String?   @unique // null = customer/non-fixture; set only by guarded integration reset
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  users            User[]
  properties       Property[]
  deals            Deal[]
  contacts         Contact[]
  documents        Document[]
  auditLogs        AuditLog[]
  auditEvents      AuditEvent[]
  emailEvents      EmailEvent[]
  modules          TenantModule[]
  workflowRules    TenantWorkflowRule[]
  parcelDataCaches ParcelDataCache[]
  prePurchaseResearchSnapshots PrePurchaseResearchSnapshot[]
  exitEvaluations  ExitEvaluation[]
  investorProfile  InvestorProfile?
  parcelResearchRequests ParcelResearchRequest[]
  jurisdictionResearchDemands JurisdictionResearchDemand[]
  jurisdictionCoverageNotifications JurisdictionCoverageNotification[]
  mfLpInvestors    DealMfLpInvestor[]
  mfWaterfalls     DealMfWaterfall[]
  checklistTemplates ChecklistTemplate[]
}

model TenantWorkflowRule {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  strategy     StrategyType
  name         String
  triggerEvent String // EventType key
  offsetDays   Int          @default(0)
  action       String       @default("CREATE_TASK")
  actionConfig Json
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId, strategy])
}

model TenantModule {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  strategy    StrategyType
  tier        ModuleTier   @default(STANDARD)
  trialEndsAt DateTime?
  createdAt   DateTime     @default(now())

  @@unique([tenantId, strategy])
  @@index([tenantId])
}

model ModulePrice {
  id            String       @id @default(cuid())
  strategy      StrategyType
  tier          ModuleTier
  stripePriceId String?
  displayPrice  Decimal?     @db.Decimal(10, 2)
  currency      String       @default("usd")
  isActive      Boolean      @default(true)
  updatedAt     DateTime     @updatedAt

  @@unique([strategy, tier])
}

// HUD Fair Market Rent reference data (keyed to state/county/year/bedrooms)
// Populated by the jurisdiction data program (#131); read-only from deal pages.
model FmrRate {
  id       String  @id @default(cuid())
  state    String
  county   String
  year     Int
  bedrooms Int // 0=studio, 1=1BR, 2=2BR, etc.
  amount   Decimal @db.Decimal(10, 2)

  @@unique([state, county, year, bedrooms])
  @@index([state, county])
}

model InvestorProfile {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  maxPurchasePrice    Float?
  improvementCapital  Float?
  holdMonthsTolerance Int?
  targetRoi           Float?
  financing           String
  licenseTypes        String[] @default([])
  updatedAt           DateTime @updatedAt

  @@index([tenantId])
}

model User {
  id           String    @id @default(cuid())
  clerkUserId  String
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         UserRole  @default(ANALYST)
  email        String
  name         String?
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedTasks Task[]
  taskComments  TaskComment[]
  auditLogs     AuditLog[]

  @@unique([clerkUserId, tenantId])
  @@index([tenantId])
}

// ============================================================
// JURISDICTIONS AND RULES ENGINE
// ============================================================

model Jurisdiction {
  id             String         @id @default(cuid())
  state          String
  stateName      String
  county         String
  fips           String?        @unique
  timezone       String         @default("America/New_York")
  investmentType InvestmentType
  notes          String?
  links          Json? // { assessorUrl, taxCollectorUrl, recorderUrl, gisUrl }
  isAvailable    Boolean        @default(false) // enabled for deal creation; auto-set when a ruleset is activated
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  ruleSets             RuleSet[]
  properties           Property[]
  strategyData         JurisdictionStrategyData[]
  profile              JurisdictionProfile?
  sourceUrls           JurisdictionSourceUrl[]
  sourceDiscoveryLeads JurisdictionSourceDiscoveryLead[]
  evidenceSnapshots    JurisdictionEvidenceSnapshot[]
  extractionCandidates ExtractionCandidate[]
  claims               JurisdictionClaim[]
  claimContradictionReviews JurisdictionClaimContradictionReview[]
  sourceAuthorityReviews JurisdictionSourceAuthorityReview[]
  auctionSaleFeeds     AuctionSaleFeed[]
  researchWork         JurisdictionResearchWork?
  researchDemands      JurisdictionResearchDemand[]
  coverageNotifications JurisdictionCoverageNotification[]
  prePurchaseResearchSnapshots PrePurchaseResearchSnapshot[]

  @@unique([state, county])
}

// Discovery output is deliberately separate from a source record. A lead can be
// a statewide directory or other starting point; it is not evidence that a
// county office URL is authoritative or suitable for extraction.
model JurisdictionSourceDiscoveryLead {
  id                 String                            @id @default(cuid())
  jurisdictionId     String
  jurisdiction       Jurisdiction                      @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  adapterId          String
  officeType         String
  url                String
  authorityOwner     String?
  authorityRationale String                            @db.Text
  candidateScope     JurisdictionSourceDiscoveryCandidateScope @default(DISCOVERY_ENTRYPOINT)
  status             JurisdictionSourceDiscoveryStatus @default(PENDING_REVIEW)
  promotedSourceUrlId String?
  promotedSourceUrl   JurisdictionSourceUrl?           @relation("DiscoveryLeadPromotion", fields: [promotedSourceUrlId], references: [id], onDelete: SetNull)
  promotedAt          DateTime?
  promotedBy          String?
  discoveredAt       DateTime
  createdAt          DateTime                          @default(now())
  updatedAt          DateTime                          @updatedAt

  @@unique([jurisdictionId, adapterId, officeType, url])
  @@index([jurisdictionId, status])
}

model JurisdictionStrategyData {
  id             String       @id @default(cuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  strategy       StrategyType
  data           Json
  updatedAt      DateTime     @updatedAt
  updatedBy      String?

  @@unique([jurisdictionId, strategy])
  @@index([jurisdictionId])
}

model JurisdictionProfile {
  id             String       @id @default(cuid())
  jurisdictionId String       @unique
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  taxSale        Json @default("{}")
  foreclosure    Json @default("{}")
  recording      Json @default("{}")
  zoning         Json @default("{}")
  physical       Json @default("{}")
  permits        Json @default("{}")
  landlordTenant Json @default("{}")
  section8       Json @default("{}")
  wholesale      Json @default("{}")
  marketSignals  Json @default("{}")
  contacts       Json @default("{}")

  publishedSections String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jurisdictionId])
}

// Shared execution state. This is deliberately not a coverage verdict: investor-visible
// coverage is derived from claims, evidence, freshness, and pending contradictions.
model JurisdictionResearchWork {
  id             String                         @id @default(cuid())
  jurisdictionId String                         @unique
  jurisdiction   Jurisdiction                   @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  status         JurisdictionResearchWorkStatus @default(DISCOVERING)
  requestedAt    DateTime                       @default(now())
  startedAt      DateTime?
  pausedAt       DateTime?
  pausedReason   String?                        @db.Text
  updatedAt      DateTime                       @updatedAt

  @@index([status, requestedAt])
}

// Tenant demand is isolated even though county research work is shared globally.
model JurisdictionResearchDemand {
  id             String       @id @default(cuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy    String
  requestedAt    DateTime     @default(now())
  notifiedAt     DateTime?

  coverageNotifications JurisdictionCoverageNotification[]

  @@unique([jurisdictionId, tenantId])
  @@index([tenantId, requestedAt])
  @@index([jurisdictionId, requestedAt])
}

// Durable tenant-scoped delivery work. A notification is created only for an
// evidence-backed verified coverage version; it is not a research-work verdict.
model JurisdictionCoverageNotification {
  id              String   @id @default(cuid())
  demandId        String
  demand          JurisdictionResearchDemand @relation(fields: [demandId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jurisdictionId  String
  jurisdiction    Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  coverageVersion String
  kind            String   @default("VERIFIED_COVERAGE")
  recipientEmail  String?
  status          String   @default("PENDING") // PENDING, SENT, SUNK, SKIPPED_NO_RECIPIENT, FAILED
  attemptedAt     DateTime?
  deliveredAt     DateTime?
  providerMessageId String?
  failureCode     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, jurisdictionId, coverageVersion, kind])
  @@index([status, createdAt])
  @@index([jurisdictionId, createdAt])
}

model JurisdictionSourceUrl {
  id                  String                            @id @default(cuid())
  jurisdictionId      String
  jurisdiction        Jurisdiction                      @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  officeType          String // assessor | tax_collector | recorder | gis | planning_zoning | building
  url                 String
  lastFetchedAt       DateTime?
  lastContentHash     String?
  authorityClass      String?
  authorityOwner      String?
  authorityStatus     JurisdictionSourceAuthorityStatus @default(UNVERIFIED)
  authorityVerifiedAt DateTime?
  authorityVerifiedBy String?
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt

  candidates       ExtractionCandidate[]
  claimEvidence    JurisdictionClaimEvidence[]
  authorityReviews JurisdictionSourceAuthorityReview[]
  evidenceSnapshots JurisdictionEvidenceSnapshot[]
  claimReReviews JurisdictionClaimReReview[]
  claimContradictionReviews JurisdictionClaimContradictionReview[]
  discoveryLeadPromotions JurisdictionSourceDiscoveryLead[] @relation("DiscoveryLeadPromotion")

  @@unique([jurisdictionId, officeType, url])
  @@index([jurisdictionId])
}

// Append-only operator decisions. The source row above is only the current authority projection.
model JurisdictionSourceAuthorityReview {
  id                String                            @id @default(cuid())
  jurisdictionId    String
  jurisdiction      Jurisdiction                      @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  sourceUrlId       String?
  sourceUrlRecord   JurisdictionSourceUrl?             @relation(fields: [sourceUrlId], references: [id], onDelete: SetNull)
  sourceUrl         String
  officeType        String
  sourceContentHash String?
  sourceUpdatedAt   DateTime
  decision          JurisdictionSourceAuthorityStatus
  authorityClass    String?
  authorityOwner    String?
  evidenceUrl       String?
  explanation       String                            @db.Text
  reviewedAt        DateTime                          @default(now())
  reviewedBy        String

  @@index([jurisdictionId, reviewedAt])
  @@index([sourceUrlId, reviewedAt])
  @@index([decision, reviewedAt])
}

// Append-only retrieval events. The R2 object is immutable and content-addressed;
// repeated retrievals of unchanged bytes intentionally create distinct rows.
model JurisdictionEvidenceSnapshot {
  id                      String                                @id @default(cuid())
  jurisdictionId          String
  jurisdiction            Jurisdiction                          @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  sourceUrlId             String?
  sourceUrlRecord         JurisdictionSourceUrl?                 @relation(fields: [sourceUrlId], references: [id], onDelete: SetNull)
  sourceUrl               String
  retrievedAt             DateTime
  retrievalAdapter        JurisdictionEvidenceRetrievalAdapter
  representationMediaType String
  contentHash             String
  storageKey              String
  byteLength              Int
  createdAt               DateTime                              @default(now())

  candidates    ExtractionCandidate[]
  claimEvidence JurisdictionClaimEvidence[]
  freshnessProjections JurisdictionClaimFreshness[] @relation("FreshnessLastSnapshot")
  claimReReviews JurisdictionClaimReReview[]
  claimContradictionReviews JurisdictionClaimContradictionReview[]

  @@index([jurisdictionId, retrievedAt])
  @@index([sourceUrlId, retrievedAt])
  @@index([contentHash])
  @@index([storageKey])
}

model ExtractionCandidate {
  id             String                 @id @default(cuid())
  jurisdictionId String
  jurisdiction   Jurisdiction           @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  sourceUrlId    String?
  sourceUrl      JurisdictionSourceUrl? @relation(fields: [sourceUrlId], references: [id], onDelete: SetNull)
  evidenceSnapshotId String?
  evidenceSnapshot   JurisdictionEvidenceSnapshot? @relation(fields: [evidenceSnapshotId], references: [id], onDelete: SetNull)
  section        String
  fieldKey       String
  extractedValue Json
  confidence     Float
  sourceSnippet  String?
  modelUsed      String
  status         ExtractionStatus       @default(PENDING)
  reviewedAt     DateTime?
  reviewedBy     String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  claimEvidence JurisdictionClaimEvidence[]
  contradictionReviews JurisdictionClaimContradictionReview[]

  @@index([jurisdictionId])
  @@index([status])
  @@index([jurisdictionId, section, fieldKey])
}

// Append-only fact history. JurisdictionProfile is the current read projection, not provenance truth.
model JurisdictionClaim {
  id                        String                             @id @default(cuid())
  jurisdictionId            String
  jurisdiction              Jurisdiction                       @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  questionId                String
  questionSchemaVersion     String
  section                   String
  fieldKey                  String
  value                     Json
  normalizedUnit            String?
  expectedAuthorityClass    String
  sourceAuthorityClass      String?
  sourceAuthorityOwner      String?
  sourceAuthorityStatus     JurisdictionSourceAuthorityStatus  @default(UNVERIFIED)
  sourceAuthorityVerifiedAt DateTime?
  sourceAuthorityVerifiedBy String?
  verificationState         JurisdictionClaimVerificationState @default(REVIEWED)
  risk                      JurisdictionClaimRisk                @default(UNKNOWN)
  volatility                JurisdictionClaimVolatility          @default(UNKNOWN)
  geographicScope           String?
  effectiveAt               DateTime?
  reviewedAt                DateTime
  reviewedBy                String
  supersedesClaimId         String?                            @unique
  supersedesClaim           JurisdictionClaim?                 @relation("JurisdictionClaimSupersession", fields: [supersedesClaimId], references: [id], onDelete: SetNull)
  supersededByClaim         JurisdictionClaim?                 @relation("JurisdictionClaimSupersession")
  createdAt                 DateTime                           @default(now())

  evidence JurisdictionClaimEvidence[]
  freshness JurisdictionClaimFreshness?
  reReviews JurisdictionClaimReReview[]
  contradictionReviewsAsExisting JurisdictionClaimContradictionReview[] @relation("ContradictionExistingClaim")
  contradictionReviewsAsReplacement JurisdictionClaimContradictionReview[] @relation("ContradictionReplacementClaim")

  @@index([jurisdictionId, questionId, createdAt])
  @@index([jurisdictionId, section, fieldKey, createdAt])
  @@index([verificationState])
}

// Mutable scheduling projection. Claim values and re-review decisions remain append-only.
model JurisdictionClaimFreshness {
  claimId                 String   @id
  claim                   JurisdictionClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  lastEvidenceSnapshotId  String?
  lastEvidenceSnapshot    JurisdictionEvidenceSnapshot? @relation("FreshnessLastSnapshot", fields: [lastEvidenceSnapshotId], references: [id], onDelete: SetNull)
  lastEvidenceRetrievedAt DateTime
  reviewDueAt             DateTime
  staleAt                 DateTime
  policyVersion           String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([reviewDueAt])
  @@index([staleAt])
}

// Append-only human reconfirmations against a newer unchanged evidence snapshot.
model JurisdictionClaimReReview {
  id                      String   @id @default(cuid())
  claimId                 String
  claim                   JurisdictionClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  evidenceSnapshotId      String
  evidenceSnapshot        JurisdictionEvidenceSnapshot @relation(fields: [evidenceSnapshotId], references: [id], onDelete: Restrict)
  sourceUrlId             String?
  sourceUrlRecord         JurisdictionSourceUrl? @relation(fields: [sourceUrlId], references: [id], onDelete: SetNull)
  sourceUrl               String
  contentHash             String
  storageKey              String
  retrievalAdapter        JurisdictionEvidenceRetrievalAdapter
  representationMediaType String
  byteLength              Int
  evidenceRetrievedAt     DateTime
  decision                JurisdictionClaimReReviewDecision @default(RECONFIRMED)
  previousReviewDueAt     DateTime
  previousStaleAt         DateTime
  nextReviewDueAt         DateTime
  nextStaleAt             DateTime
  policyVersion           String
  explanation             String @db.Text
  reviewedAt              DateTime @default(now())
  reviewedBy              String

  @@index([claimId, reviewedAt])
  @@index([evidenceSnapshotId])
  @@index([sourceUrlId])
}

// Append-only operator decisions for a pending candidate that disagreed with the active claim.
model JurisdictionClaimContradictionReview {
  id                          String   @id @default(cuid())
  jurisdictionId              String
  jurisdiction                Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  questionId                  String
  questionSchemaVersion       String
  section                     String
  fieldKey                    String
  existingClaimId             String
  existingClaim               JurisdictionClaim @relation("ContradictionExistingClaim", fields: [existingClaimId], references: [id], onDelete: Cascade)
  replacementClaimId          String?
  replacementClaim            JurisdictionClaim? @relation("ContradictionReplacementClaim", fields: [replacementClaimId], references: [id], onDelete: SetNull)
  candidateId                 String?
  candidate                   ExtractionCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  candidateReferenceId        String
  candidateUpdatedAt          DateTime
  evidenceSnapshotId          String?
  evidenceSnapshot            JurisdictionEvidenceSnapshot? @relation(fields: [evidenceSnapshotId], references: [id], onDelete: SetNull)
  evidenceSnapshotReferenceId String
  sourceUrlId                 String?
  sourceUrlRecord             JurisdictionSourceUrl? @relation(fields: [sourceUrlId], references: [id], onDelete: SetNull)
  existingValue               Json
  proposedValue               Json
  existingNormalizedUnit      String?
  proposedNormalizedUnit      String?
  sourceUrl                   String
  sourceSnippet               String   @db.Text
  evidenceRetrievedAt         DateTime
  contentHash                 String
  storageKey                  String
  retrievalAdapter            JurisdictionEvidenceRetrievalAdapter
  representationMediaType     String
  byteLength                  Int
  modelUsed                   String
  decision                    JurisdictionClaimContradictionDecision
  explanation                 String   @db.Text
  reviewedAt                  DateTime @default(now())
  reviewedBy                  String
  createdAt                   DateTime @default(now())

  @@index([jurisdictionId, section, fieldKey, reviewedAt])
  @@index([existingClaimId, reviewedAt])
  @@index([replacementClaimId])
  @@index([candidateId])
  @@index([evidenceSnapshotId])
}

// Evidence is copied at publication time so provenance survives source/candidate cleanup.
model JurisdictionClaimEvidence {
  id              String                 @id @default(cuid())
  claimId         String
  claim           JurisdictionClaim      @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sourceUrlId     String?
  sourceUrlRecord JurisdictionSourceUrl? @relation(fields: [sourceUrlId], references: [id], onDelete: SetNull)
  candidateId     String?
  candidate       ExtractionCandidate?   @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  evidenceSnapshotId String?
  evidenceSnapshot   JurisdictionEvidenceSnapshot? @relation(fields: [evidenceSnapshotId], references: [id], onDelete: SetNull)
  sourceUrl       String
  sourceSnippet   String                 @db.Text
  retrievedAt     DateTime
  contentHash     String?
  storageKey      String?
  retrievalAdapter JurisdictionEvidenceRetrievalAdapter?
  representationMediaType String?
  byteLength      Int?
  modelUsed       String?
  createdAt       DateTime               @default(now())

  @@index([claimId])
  @@index([sourceUrlId])
  @@index([candidateId])
  @@index([evidenceSnapshotId])
}

model AuctionSaleFeed {
  id                      String            @id @default(cuid())
  jurisdictionId          String
  jurisdiction            Jurisdiction      @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  source                  AuctionFeedSource
  saleDate                DateTime
  registrationDeadline    DateTime?
  depositRequirementCents Int?
  platformUrl             String?
  notes                   String?
  syncedAt                DateTime          @default(now())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@unique([jurisdictionId, source, saleDate])
  @@index([jurisdictionId])
  @@index([saleDate])
  @@index([source])
}

model RuleSet {
  id             String       @id @default(cuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String
  effectiveDate  DateTime
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  rules Rule[]

  @@index([jurisdictionId])
}

// Formula: dueDate = deal[anchorField] + offsetDays
model Rule {
  id          String    @id @default(cuid())
  ruleSetId   String
  ruleSet     RuleSet   @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  eventType   EventType
  label       String
  anchorField String
  offsetDays  Int
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([ruleSetId])
}

// ============================================================
// PROPERTY AND CONTACTS
// ============================================================

model Property {
  id               String       @id @default(cuid())
  tenantId         String
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jurisdictionId   String
  jurisdiction     Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  apn              String
  address          String?
  city             String?
  state            String?
  zip              String?
  legalDescription String?
  propertyType     String?
  acres            Decimal?     @db.Decimal(10, 4)
  sqft             Int?
  beds             Int?
  baths            Decimal?     @db.Decimal(4, 1)
  yearBuilt        Int?
  assessedValue    Decimal?     @db.Decimal(14, 2)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  deals     Deal[]
  contacts  Contact[]  @relation("PropertyContacts")
  documents Document[]

  @@unique([tenantId, apn, jurisdictionId])
  @@index([tenantId])
}

model ParcelDataCache {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apnNormalized String
  fipsCounty    String
  source        String
  field         String
  valueJson     Json
  normalized    Json?
  retrievedAt   DateTime
  ttlHours      Int
  expiresAt     DateTime
  metadata      Json?

  @@unique([tenantId, apnNormalized, fipsCounty, source, field])
  @@index([tenantId, apnNormalized, fipsCounty])
  @@index([expiresAt])
}

// A bounded, tenant-scoped record of the output shown to an investor before
// they choose to create a deal. It is evidence, not verified property data.
model PrePurchaseResearchSnapshot {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  apn            String
  payload        Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?
  consumedDealId String?

  @@index([tenantId, expiresAt])
  @@index([tenantId, jurisdictionId, apn])
  @@index([consumedDealId])
}

model Contact {
  id            String               @id @default(cuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type          ContactType
  pipelineStage ContactPipelineStage @default(LEAD)
  firstName     String?
  lastName      String?
  company       String?
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  zip           String?
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  properties        Property[]       @relation("PropertyContacts")
  deals             Deal[]
  buyerProfile      BuyerProfile?
  wholesaleDeals    DealWholesale[]  @relation("WholesaleBuyer")
  buyerBlastSends   BuyerBlastSend[]
  activities        ContactActivity[]
  fixFlipContracts  DealFixFlip[]
  buyHoldTenancies  DealBuyHold[]    @relation("BuyHoldTenant")
  buyHoldManagedProps DealBuyHold[]  @relation("BuyHoldPM")
  multifamilyManaged DealMultifamily[] @relation("MultifamilyPM")
  landNotesBuyer    LandNote[]       @relation("LandNoteBuyer")
  mfLpInvestments   DealMfLpInvestor[] @relation("MfLpInvestor")

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, pipelineStage])
}

model ContactActivity {
  id         String              @id @default(cuid())
  contactId  String
  contact    Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId   String
  type       ContactActivityType
  notes      String?
  occurredAt DateTime            @default(now())
  createdAt  DateTime            @default(now())

  @@index([contactId])
  @@index([tenantId])
}

model BuyerProfile {
  id                 String   @id @default(cuid())
  contactId          String   @unique
  contact            Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId           String
  priceMin           Decimal? @db.Decimal(14, 2)
  priceMax           Decimal? @db.Decimal(14, 2)
  assignmentFeeMax   Decimal? @db.Decimal(14, 2)
  preferredStates    String[]
  preferredPropTypes String[]
  isActive           Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
}

// ============================================================
// DEAL — Universal investment container
// ============================================================

model Deal {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property     @relation(fields: [propertyId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  strategyType  StrategyType
  status        DealStatus   @default(LEAD)
  purchasePrice Decimal?     @db.Decimal(14, 2)
  purchaseDate  DateTime?
  exitPrice     Decimal?     @db.Decimal(14, 2)
  exitDate      DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  taxLien         DealTaxLien?
  taxDeed         DealTaxDeed?
  foreclosure     DealForeclosure?
  fixFlip         DealFixFlip?
  land            DealLand?
  wholesale       DealWholesale?
  buyHold         DealBuyHold?
  multifamily     DealMultifamily?
  events          Event[]
  tasks           Task[]
  transactions    FinancialTransaction[]
  documents       Document[]
  auditLogs       AuditLog[]
  landNotes       LandNote[]
  landComps       LandComp[]
  buyerBlastSends BuyerBlastSend[]
  exitEvaluations ExitEvaluation[]
  parcelResearchRequests ParcelResearchRequest[]
  mfLpInvestors   DealMfLpInvestor[]
  mfWaterfall     DealMfWaterfall?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, strategyType])
}

model ParcelResearchRequest {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  apnNormalized   String
  fipsCounty      String
  status          String
  priority        String
  requestedAt     DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  adminUserId     String?
  notes           String?
  fieldsCompleted String[] @default([])

  @@index([tenantId, status])
  @@index([status, requestedAt])
}

model ExitEvaluation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  investorProfile Json
  results         Json
  parcelSnapshot  Json
  evaluatedAt     DateTime
  expiresAt       DateTime
  version         String

  @@index([tenantId, dealId])
  @@index([expiresAt])
}

// Extension table — Tax Deed strategy
model DealTaxDeed {
  id                   String    @id @default(cuid())
  dealId               String    @unique
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  // Auction details
  saleDate             DateTime?
  openingBid           Decimal?  @db.Decimal(14, 2)
  winningBid           Decimal?  @db.Decimal(14, 2)
  auctionDate          DateTime? // for leads — scheduled auction date
  maxBid               Decimal?  @db.Decimal(14, 2)
  // Redemption tracking
  redemptionPeriodDays Int?
  redemptionDeadline   DateTime?
  isRedeemed           Boolean   @default(false)
  redemptionAmount     Decimal?  @db.Decimal(14, 2)
  redemptionDate       DateTime?
  // Deed recorded
  deedRecordedDate     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// Extension table — Foreclosure Auction strategy
model DealForeclosure {
  id                 String    @id @default(cuid())
  dealId             String    @unique
  deal               Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  foreclosureType    String    @default("MORTGAGE") // MORTGAGE | TAX | HOA
  // Pre-foreclosure / lead tracking
  nodFiledDate       DateTime? // Notice of Default filed date
  lisFiledDate       DateTime? // Lis pendens filed date
  estimatedLiens     Decimal?  @db.Decimal(14, 2)
  auctionDate        DateTime?
  maxBid             Decimal?  @db.Decimal(14, 2)
  // Post-auction
  openingBid         Decimal?  @db.Decimal(14, 2)
  winningBid         Decimal?  @db.Decimal(14, 2)
  redemptionDeadline DateTime?
  // Title / condition
  titleIssues        Json?
  propertyCondition  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// Extension table — Fix & Flip strategy
model DealFixFlip {
  id                    String    @id @default(cuid())
  dealId                String    @unique
  deal                  Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  arv                   Decimal?  @db.Decimal(14, 2) // after-repair value
  rehabBudget           Decimal?  @db.Decimal(14, 2)
  rehabActualCost       Decimal?  @db.Decimal(14, 2)
  contractorContactId   String?
  contractorContact     Contact?  @relation(fields: [contractorContactId], references: [id], onDelete: SetNull)
  contractorName        String?
  contractorPhone       String?
  contractorEmail       String?
  permitStatus          String?
  rehabStartDate        DateTime?
  rehabTargetCompletion DateTime?
  rehabCompletedDate    DateTime?
  listingDate           DateTime?
  listingPrice          Decimal?  @db.Decimal(14, 2)
  acceptedOfferDate     DateTime?
  acceptedOfferPrice    Decimal?  @db.Decimal(14, 2)
  closingDate           DateTime?
  holdingCostEstimate   Decimal?  @db.Decimal(14, 2)
  scopeOfWork           Json?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// Extension table — Land Investing strategy
model DealLand {
  id                 String                 @id @default(cuid())
  dealId             String                 @unique
  deal               Deal                   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  zoning             String?
  access             LandAccess?
  utilities          Json? // { water, sewer, electric, gas, notes }
  floodZone          String?
  wetlandsPercent    Decimal?               @db.Decimal(5, 2)
  hoaName            String?
  hoaFees            Decimal?               @db.Decimal(14, 2)
  optionExpiry       DateTime?
  sellerFinanceTerms Json?
  buyerFinanceTerms  Json?
  // Disposition funnel
  dispositionStatus  LandDispositionStatus?
  listedPrice        Decimal?               @db.Decimal(14, 2)
  dispositionDate    DateTime?
  // AI parcel summary — regenerated on demand, never auto-refreshed
  aiSummary           String?               @db.Text
  aiSummaryGeneratedAt DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

// Comparable raw land sale logged against a Land deal for valuation context
model LandComp {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenantId  String
  address   String?
  apn       String?
  acres     Decimal  @db.Decimal(10, 4)
  salePrice Decimal  @db.Decimal(14, 2)
  saleDate  DateTime
  sourceUrl String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([tenantId])
}

// Seller-finance note on a Land deal — one active note at a time; archived on default/payoff
model LandNote {
  id               String         @id @default(cuid())
  dealId           String
  deal             Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenantId         String
  buyerContactId   String?
  buyerContact     Contact?       @relation("LandNoteBuyer", fields: [buyerContactId], references: [id], onDelete: SetNull)
  buyerName        String?
  buyerEmail       String?
  buyerPhone       String?
  principal        Decimal        @db.Decimal(14, 2)
  interestRate     Decimal        @db.Decimal(6, 4) // stored as fraction, e.g. 0.08 = 8%
  termMonths       Int
  paymentAmount    Decimal        @db.Decimal(14, 2)
  firstPaymentDate DateTime
  balance          Decimal        @db.Decimal(14, 2)
  status           LandNoteStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([dealId])
  @@index([tenantId])
}

// Buyer-blast send log (per-contact per-deal)
model BuyerBlastSend {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sentAt    DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([tenantId])
  @@index([dealId])
}

// Extension table — Wholesale strategy
model DealWholesale {
  id                 String    @id @default(cuid())
  dealId             String    @unique
  deal               Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  leadSource         String?
  contractDate       DateTime?
  contractPrice      Decimal?  @db.Decimal(14, 2)
  earnestMoney       Decimal?  @db.Decimal(14, 2)
  inspectionDeadline DateTime?
  closingDeadline    DateTime?
  assignmentFee      Decimal?  @db.Decimal(14, 2)
  buyerName          String?
  buyerEmail         String?
  buyerPhone         String?
  buyerContactId     String?
  buyerContact       Contact?  @relation("WholesaleBuyer", fields: [buyerContactId], references: [id], onDelete: SetNull)
  dispositionStatus  String?
  marketingNotes     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([buyerContactId])
}

// Extension table — Buy & Hold / Section 8 strategy
model DealBuyHold {
  id                     String    @id @default(cuid())
  dealId                 String    @unique
  deal                   Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  rentalStrategy         String? // LONG_TERM | SHORT_TERM | MID_TERM | SECTION_8
  targetMonthlyRent      Decimal?  @db.Decimal(14, 2)
  actualMonthlyRent      Decimal?  @db.Decimal(14, 2)
  securityDeposit        Decimal?  @db.Decimal(14, 2)
  leaseStartDate         DateTime?
  leaseEndDate           DateTime?
  tenantContactId        String?
  tenantContact          Contact?  @relation("BuyHoldTenant", fields: [tenantContactId], references: [id], onDelete: SetNull)
  tenantName             String?
  tenantPhone            String?
  tenantEmail            String?
  propertyManagerContactId String?
  propertyManagerContact Contact?  @relation("BuyHoldPM", fields: [propertyManagerContactId], references: [id], onDelete: SetNull)
  propertyManagerName    String?
  propertyManagerPhone   String?
  propertyManagerEmail   String?
  section8VoucherAmount  Decimal?  @db.Decimal(14, 2)
  housingAuthorityName   String?
  inspectionStatus       String?
  // Section 8 premium fields
  hapContractNumber      String?
  hapMonthlyAmount       Decimal?  @db.Decimal(14, 2)
  tenantPortion          Decimal?  @db.Decimal(14, 2)
  hapAnniversary         DateTime?
  nextHqsDate            DateTime?
  hqsResult              String? // PASS | FAIL | PENDING
  fmrBedrooms            Int?
  rentIncreaseNoticeDays Int?      @default(60)
  operatingExpenses      Json?
  maintenanceReserve     Decimal?  @db.Decimal(14, 2)
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

// Extension table — Multifamily strategy
model DealMultifamily {
  id                   String    @id @default(cuid())
  dealId               String    @unique
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  unitCount            Int?
  occupiedUnits        Int?
  averageMonthlyRent   Decimal?  @db.Decimal(14, 2)
  grossScheduledIncome Decimal?  @db.Decimal(14, 2)
  vacancyRate          Decimal?  @db.Decimal(5, 2)
  operatingExpenses    Json?
  netOperatingIncome   Decimal?  @db.Decimal(14, 2)
  capRate              Decimal?  @db.Decimal(6, 4)
  dscr                 Decimal?  @db.Decimal(6, 4)
  loanAmount           Decimal?  @db.Decimal(14, 2)
  interestRate         Decimal?  @db.Decimal(6, 4)
  amortizationYears    Int?
  annualDebtService    Decimal?  @db.Decimal(14, 2)
  loanMaturityDate     DateTime?
  rentRoll             Json?
  t12Financials        Json?
  businessPlan         Json?
  propertyManagerContactId String?
  propertyManagerContact   Contact?  @relation("MultifamilyPM", fields: [propertyManagerContactId], references: [id], onDelete: SetNull)
  propertyManagerName  String?
  propertyManagerPhone String?
  propertyManagerEmail String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// LP investor record for a multifamily syndication deal
model DealMfLpInvestor {
  id              String   @id @default(cuid())
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact? @relation("MfLpInvestor", fields: [contactId], references: [id], onDelete: SetNull)
  name            String
  email           String?
  phone           String?
  committedAmount Decimal  @db.Decimal(14, 2)
  fundedAmount    Decimal  @default(0) @db.Decimal(14, 2)
  equityPct       Decimal? @db.Decimal(6, 4) // manual override; null = auto from funded/total
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dealId])
  @@index([tenantId])
}

// Waterfall parameters for a multifamily syndication deal
model DealMfWaterfall {
  id                  String    @id @default(cuid())
  dealId              String    @unique
  deal                Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  preferredReturnRate Decimal   @db.Decimal(6, 4) // e.g. 0.08 for 8% annual
  lpSplit             Decimal   @db.Decimal(5, 4) // LP equity share above pref, e.g. 0.80
  gpSplit             Decimal   @db.Decimal(5, 4) // GP equity share above pref, e.g. 0.20
  promoteHurdle       Decimal?  @db.Decimal(6, 4) // IRR hurdle for promote, e.g. 0.12
  promoteCarry        Decimal?  @db.Decimal(5, 4) // GP carry above hurdle, e.g. 0.30
  raisedDate          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([tenantId])
}

// Extension table — Tax Lien strategy
model DealTaxLien {
  id                      String    @id @default(cuid())
  dealId                  String    @unique
  deal                    Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  // Certificate details — required for ACTIVE deals, optional for LEAD/pre-bid
  certificateNumber       String?
  faceAmount              Decimal?  @db.Decimal(14, 2)
  interestRate            Decimal?  @db.Decimal(6, 4)
  penaltyRate             Decimal?  @db.Decimal(6, 4)
  issueDate               DateTime?
  saleDate                DateTime?
  // Lead / pre-bid tracking
  auctionDate             DateTime? // scheduled auction date
  maxBid                  Decimal?  @db.Decimal(14, 2) // max bid amount
  // Post-purchase tracking
  redemptionDeadline      DateTime?
  foreclosureEligibleDate DateTime?
  redemptionAmount        Decimal?  @db.Decimal(14, 2)
  redemptionDate          DateTime?
  isRedeemed              Boolean   @default(false)
  subsequentTaxesPaid     Decimal?  @db.Decimal(14, 2)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

// ============================================================
// EVENTS — Rule-derived milestones
// ============================================================

model Event {
  id            String      @id @default(cuid())
  dealId        String
  deal          Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  ruleId        String?
  eventType     EventType
  label         String
  dueDate       DateTime
  completedDate DateTime?
  status        EventStatus @default(PENDING)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tasks Task[]

  @@index([dealId])
  @@index([dueDate, status])
}

// ============================================================
// TASKS — Operational actions
// ============================================================

model Task {
  id           String     @id @default(cuid())
  dealId       String
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  eventId      String?
  event        Event?     @relation(fields: [eventId], references: [id])
  assignedToId String?
  assignedTo   User?      @relation(fields: [assignedToId], references: [id])
  tenantId     String
  taskType     TaskType
  title        String
  description  String?
  dueDate      DateTime?
  completedAt  DateTime?
  status       TaskStatus @default(OPEN)
  priority     Priority   @default(MEDIUM)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  checklistKey String? // set when created via checklist template; used for idempotency

  comments TaskComment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([assignedToId, status])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
  @@index([userId])
}

// ============================================================
// FINANCIALS
// ============================================================

model FinancialTransaction {
  id          String          @id @default(cuid())
  dealId      String
  deal        Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenantId    String
  type        TransactionType
  amount      Decimal         @db.Decimal(14, 2)
  date        DateTime
  description String?
  createdAt   DateTime        @default(now())

  @@index([dealId])
  @@index([tenantId])
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId        String?
  deal          Deal?        @relation(fields: [dealId], references: [id])
  propertyId    String?
  property      Property?    @relation(fields: [propertyId], references: [id])
  fileName      String
  fileSize      Int
  mimeType      String
  r2Key         String       @unique
  docType       DocumentType
  extractedData Json?
  uploadedAt    DateTime     @default(now())

  @@index([tenantId])
  @@index([dealId])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id])
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([dealId])
  @@index([entityType, entityId])
}

model AuditEvent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  requestId String?
  action    String // DEAL_CREATED, DEAL_ARCHIVED, BLAST_SENT, NOTE_PAYMENT_LOGGED, CHECKLIST_CREATED, LOGIN
  meta      Json? // contextual data: { dealId, strategy, amount, etc. }
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, requestId])
}

model Announcement {
  id        String   @id @default(cuid())
  message   String
  severity  String   @default("INFO") // INFO, WARNING
  startsAt  DateTime @default(now())
  endsAt    DateTime
  createdAt DateTime @default(now())
  createdBy String?
}

model ChecklistTemplate {
  id        String       @id @default(cuid())
  tenantId  String? // null = system template; set = tenant override
  tenant    Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  strategy  StrategyType
  name      String
  items     Json // ChecklistItem[]
  isActive  Boolean      @default(true)
  version   Int          @default(1)
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, strategy])
  @@index([strategy])
}

model EmailEvent {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  type      String // 'bounced', 'complained', 'delivery_delayed', 'opened', 'clicked'
  email     String
  meta      Json?
  timestamp DateTime @default(now())

  @@index([type, timestamp])
  @@index([email])
}

model IntegrationResetRun {
  id                String    @id @default(cuid())
  environmentId     String
  fixtureSet        String
  fixtureVersion    String
  gitCommit         String
  requiredMigration String
  status            String
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  summary           Json?
  errorCode         String?

  @@index([environmentId, startedAt])
  @@index([fixtureSet, startedAt])
}

// ============================================================
// ENUMS
// ============================================================

enum ExtractionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JurisdictionResearchWorkStatus {
  DISCOVERING
  PAUSED
}

enum JurisdictionSourceAuthorityStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum JurisdictionSourceDiscoveryStatus {
  PENDING_REVIEW
  REJECTED
  PROMOTED
}

enum JurisdictionSourceDiscoveryCandidateScope {
  DISCOVERY_ENTRYPOINT
  COUNTY_OFFICE_CANDIDATE
}

enum JurisdictionEvidenceRetrievalAdapter {
  JINA_READER
}

enum JurisdictionClaimVolatility {
  UNKNOWN
  STATIC
  ANNUAL
  QUARTERLY
  PER_SALE
}

enum JurisdictionClaimRisk {
  UNKNOWN
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum JurisdictionClaimReReviewDecision {
  RECONFIRMED
}

enum JurisdictionClaimContradictionDecision {
  REPLACED_CURRENT
  REJECTED_CHALLENGE
  NOT_COMPARABLE
}

enum JurisdictionClaimVerificationState {
  REVIEWED
  VERIFIED
  STALE
  BLOCKED
  SUPERSEDED
}

enum PlanTier {
  STARTER
  PROFESSIONAL
  TEAM
  ENTERPRISE
}

enum ModuleTier {
  STANDARD
  PREMIUM
}

enum UserRole {
  OWNER
  ANALYST
  ATTORNEY
  ASSISTANT
  READ_ONLY
}

enum InvestmentType {
  LIEN
  DEED
  REDEEMABLE_DEED
}

enum StrategyType {
  TAX_LIEN
  TAX_DEED
  FORECLOSURE
  FIX_FLIP
  WHOLESALE
  BUY_HOLD
  LAND
  MULTIFAMILY
}

enum DealStatus {
  LEAD
  ACTIVE
  NOT_WON
  REDEEMED
  FORECLOSURE_INITIATED
  DEEDED
  SOLD
  CLOSED
  EXPIRED
}

/// Parcel access status. NONE means confirmed no legal/physical access; UNKNOWN means not yet researched.
enum LandNoteStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum LandDispositionStatus {
  LISTED
  UNDER_CONTRACT
  SOLD_CASH
  SOLD_TERMS
  RELISTED
}

enum LandAccess {
  ROAD
  EASEMENT
  LANDLOCKED
  NONE
  UNKNOWN
}

enum AuctionFeedSource {
  GOVEASE
  REALAUCTION_FL
  TAX_SALE_RESOURCES
}

enum EventType {
  REDEMPTION_DEADLINE
  NOTICE_MAIL_BY
  PUBLICATION_START
  FORECLOSURE_ELIGIBLE
  FORECLOSURE_DEADLINE
  AUCTION_DATE
  DEED_ISSUED
  OPTION_EXPIRY
  PAYMENT_LATE
  INSPECTION_END
