// ============================================================
// Metis Platform — Prisma Schema  v1.0
// Phase 1: Core entities + Tax Lien module
// Import path: import { PrismaClient } from "@/generated/prisma"
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TENANT AND USERS
// ============================================================

model Tenant {
  id                       String    @id @default(cuid())
  clerkOrgId               String    @unique
  name                     String
  slug                     String    @unique
  plan                     PlanTier  @default(STARTER)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripeSubscriptionStatus String? // active, trialing, past_due, canceled, etc.
  trialEndsAt              DateTime?
  currentPeriodEnd         DateTime?
  adminNotes               String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  users          User[]
  properties     Property[]
  deals          Deal[]
  contacts       Contact[]
  documents      Document[]
  auditLogs      AuditLog[]
  modules        TenantModule[]
  workflowRules  TenantWorkflowRule[]
}

model TenantWorkflowRule {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  strategy     StrategyType
  name         String
  triggerEvent String       // EventType key
  offsetDays   Int          @default(0)
  action       String       @default("CREATE_TASK")
  actionConfig Json
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([tenantId, strategy])
}

model TenantModule {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  strategy  StrategyType
  tier      ModuleTier  @default(STANDARD)
  createdAt DateTime    @default(now())

  @@unique([tenantId, strategy])
  @@index([tenantId])
}

// HUD Fair Market Rent reference data (keyed to state/county/year/bedrooms)
// Populated by the jurisdiction data program (#131); read-only from deal pages.
model FmrRate {
  id       String  @id @default(cuid())
  state    String
  county   String
  year     Int
  bedrooms Int     // 0=studio, 1=1BR, 2=2BR, etc.
  amount   Decimal @db.Decimal(10, 2)

  @@unique([state, county, year, bedrooms])
  @@index([state, county])
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role        UserRole @default(ANALYST)
  email       String
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedTasks Task[]
  taskComments  TaskComment[]
  auditLogs     AuditLog[]

  @@unique([clerkUserId, tenantId])
  @@index([tenantId])
}

// ============================================================
// JURISDICTIONS AND RULES ENGINE
// ============================================================

model Jurisdiction {
  id             String         @id @default(cuid())
  state          String
  stateName      String
  county         String
  timezone       String         @default("America/New_York")
  investmentType InvestmentType
  notes          String?
  links          Json? // { assessorUrl, taxCollectorUrl, recorderUrl, gisUrl }
  isAvailable    Boolean        @default(false) // enabled for deal creation; auto-set when a ruleset is activated
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  ruleSets   RuleSet[]
  properties Property[]

  @@unique([state, county])
}

model RuleSet {
  id             String       @id @default(cuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String
  effectiveDate  DateTime
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  rules Rule[]

  @@index([jurisdictionId])
}

// Formula: dueDate = deal[anchorField] + offsetDays
model Rule {
  id          String    @id @default(cuid())
  ruleSetId   String
  ruleSet     RuleSet   @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  eventType   EventType
  label       String
  anchorField String
  offsetDays  Int
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([ruleSetId])
}

// ============================================================
// PROPERTY AND CONTACTS
// ============================================================

model Property {
  id               String       @id @default(cuid())
  tenantId         String
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jurisdictionId   String
  jurisdiction     Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  apn              String
  address          String?
  city             String?
  state            String?
  zip              String?
  legalDescription String?
  propertyType     String?
  acres            Decimal?     @db.Decimal(10, 4)
  sqft             Int?
  beds             Int?
  baths            Decimal?     @db.Decimal(4, 1)
  yearBuilt        Int?
  assessedValue    Decimal?     @db.Decimal(14, 2)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  deals     Deal[]
  contacts  Contact[]  @relation("PropertyContacts")
  documents Document[]

  @@unique([tenantId, apn, jurisdictionId])
  @@index([tenantId])
}

model Contact {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      ContactType
  firstName String?
  lastName  String?
  company   String?
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  notes     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  properties      Property[]       @relation("PropertyContacts")
  deals           Deal[]
  buyerProfile    BuyerProfile?
  wholesaleDeals  DealWholesale[]  @relation("WholesaleBuyer")
  buyerBlastSends BuyerBlastSend[]

  @@index([tenantId])
}

model BuyerProfile {
  id                   String   @id @default(cuid())
  contactId            String   @unique
  contact              Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenantId             String
  priceMin             Decimal? @db.Decimal(14, 2)
  priceMax             Decimal? @db.Decimal(14, 2)
  assignmentFeeMax     Decimal? @db.Decimal(14, 2)
  preferredStates      String[]
  preferredPropTypes   String[]
  isActive             Boolean  @default(true)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId])
}

// ============================================================
// DEAL — Universal investment container
// ============================================================

model Deal {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property     @relation(fields: [propertyId], references: [id])
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id])
  strategyType  StrategyType
  status        DealStatus   @default(LEAD)
  purchasePrice Decimal?     @db.Decimal(14, 2)
  purchaseDate  DateTime?
  exitPrice     Decimal?     @db.Decimal(14, 2)
  exitDate      DateTime?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  taxLien      DealTaxLien?
  taxDeed      DealTaxDeed?
  foreclosure  DealForeclosure?
  fixFlip      DealFixFlip?
  land         DealLand?
  wholesale    DealWholesale?
  buyHold      DealBuyHold?
  multifamily  DealMultifamily?
  events       Event[]
  tasks        Task[]
  transactions FinancialTransaction[]
  documents    Document[]
  auditLogs    AuditLog[]
  landNotes      LandNote[]
  buyerBlastSends BuyerBlastSend[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, strategyType])
}

// Extension table — Tax Deed strategy
model DealTaxDeed {
  id                   String    @id @default(cuid())
  dealId               String    @unique
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  // Auction details
  saleDate             DateTime?
  openingBid           Decimal?  @db.Decimal(14, 2)
  winningBid           Decimal?  @db.Decimal(14, 2)
  auctionDate          DateTime? // for leads — scheduled auction date
  maxBid               Decimal?  @db.Decimal(14, 2)
  // Redemption tracking
  redemptionPeriodDays Int?
  redemptionDeadline   DateTime?
  isRedeemed           Boolean   @default(false)
  redemptionAmount     Decimal?  @db.Decimal(14, 2)
  redemptionDate       DateTime?
  // Deed recorded
  deedRecordedDate     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// Extension table — Foreclosure Auction strategy
model DealForeclosure {
  id                 String    @id @default(cuid())
  dealId             String    @unique
  deal               Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  foreclosureType    String    @default("MORTGAGE") // MORTGAGE | TAX | HOA
  // Pre-foreclosure / lead tracking
  nodFiledDate       DateTime? // Notice of Default filed date
  lisFiledDate       DateTime? // Lis pendens filed date
  estimatedLiens     Decimal?  @db.Decimal(14, 2)
  auctionDate        DateTime?
  maxBid             Decimal?  @db.Decimal(14, 2)
  // Post-auction
  openingBid         Decimal?  @db.Decimal(14, 2)
  winningBid         Decimal?  @db.Decimal(14, 2)
  redemptionDeadline DateTime?
  // Title / condition
  titleIssues        Json?
  propertyCondition  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// Extension table — Fix & Flip strategy
model DealFixFlip {
  id                    String    @id @default(cuid())
  dealId                String    @unique
  deal                  Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  arv                   Decimal?  @db.Decimal(14, 2) // after-repair value
  rehabBudget           Decimal?  @db.Decimal(14, 2)
  rehabActualCost       Decimal?  @db.Decimal(14, 2)
  contractorName        String?
  contractorPhone       String?
  contractorEmail       String?
  permitStatus          String?
  rehabStartDate        DateTime?
  rehabTargetCompletion DateTime?
  rehabCompletedDate    DateTime?
  listingDate           DateTime?
  listingPrice          Decimal?  @db.Decimal(14, 2)
  acceptedOfferDate     DateTime?
  acceptedOfferPrice    Decimal?  @db.Decimal(14, 2)
  closingDate           DateTime?
  holdingCostEstimate   Decimal?  @db.Decimal(14, 2)
  scopeOfWork           Json?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// Extension table — Land Investing strategy
model DealLand {
  id                 String                 @id @default(cuid())
  dealId             String                 @unique
  deal               Deal                   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  zoning             String?
  access             LandAccess?
  utilities          Json? // { water, sewer, electric, gas, notes }
  floodZone          String?
  wetlandsPercent    Decimal?               @db.Decimal(5, 2)
  hoaName            String?
  hoaFees            Decimal?               @db.Decimal(14, 2)
  optionExpiry       DateTime?
  sellerFinanceTerms Json?
  buyerFinanceTerms  Json?
  // Disposition funnel
  dispositionStatus  LandDispositionStatus?
  listedPrice        Decimal?               @db.Decimal(14, 2)
  dispositionDate    DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

// Seller-finance note on a Land deal — one active note at a time; archived on default/payoff
model LandNote {
  id               String         @id @default(cuid())
  dealId           String
  deal             Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenantId         String
  buyerName        String?
  buyerEmail       String?
  buyerPhone       String?
  principal        Decimal        @db.Decimal(14, 2)
  interestRate     Decimal        @db.Decimal(6, 4) // stored as fraction, e.g. 0.08 = 8%
  termMonths       Int
  paymentAmount    Decimal        @db.Decimal(14, 2)
  firstPaymentDate DateTime
  balance          Decimal        @db.Decimal(14, 2)
  status           LandNoteStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([dealId])
  @@index([tenantId])
}

// Buyer-blast send log (per-contact per-deal)
model BuyerBlastSend {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sentAt    DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([tenantId])
  @@index([dealId])
}

// Extension table — Wholesale strategy
model DealWholesale {
  id                 String    @id @default(cuid())
  dealId             String    @unique
  deal               Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  leadSource         String?
  contractDate       DateTime?
  contractPrice      Decimal?  @db.Decimal(14, 2)
  earnestMoney       Decimal?  @db.Decimal(14, 2)
  inspectionDeadline DateTime?
  closingDeadline    DateTime?
  assignmentFee      Decimal?  @db.Decimal(14, 2)
  buyerName          String?
  buyerEmail         String?
  buyerPhone         String?
  buyerContactId     String?
  buyerContact       Contact?  @relation("WholesaleBuyer", fields: [buyerContactId], references: [id], onDelete: SetNull)
  dispositionStatus  String?
  marketingNotes     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([buyerContactId])
}

// Extension table — Buy & Hold / Section 8 strategy
model DealBuyHold {
  id                    String    @id @default(cuid())
  dealId                String    @unique
  deal                  Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  rentalStrategy        String? // LONG_TERM | SHORT_TERM | MID_TERM | SECTION_8
  targetMonthlyRent     Decimal?  @db.Decimal(14, 2)
  actualMonthlyRent     Decimal?  @db.Decimal(14, 2)
  securityDeposit       Decimal?  @db.Decimal(14, 2)
  leaseStartDate        DateTime?
  leaseEndDate          DateTime?
  tenantName            String?
  tenantPhone           String?
  tenantEmail           String?
  propertyManagerName   String?
  propertyManagerPhone  String?
  propertyManagerEmail  String?
  section8VoucherAmount   Decimal?  @db.Decimal(14, 2)
  housingAuthorityName    String?
  inspectionStatus        String?
  // Section 8 premium fields
  hapContractNumber       String?
  hapMonthlyAmount        Decimal?  @db.Decimal(14, 2)
  tenantPortion           Decimal?  @db.Decimal(14, 2)
  hapAnniversary          DateTime?
  nextHqsDate             DateTime?
  hqsResult               String?  // PASS | FAIL | PENDING
  fmrBedrooms             Int?
  rentIncreaseNoticeDays  Int?     @default(60)
  operatingExpenses       Json?
  maintenanceReserve    Decimal?  @db.Decimal(14, 2)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// Extension table — Multifamily strategy
model DealMultifamily {
  id                   String    @id @default(cuid())
  dealId               String    @unique
  deal                 Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  unitCount            Int?
  occupiedUnits        Int?
  averageMonthlyRent   Decimal?  @db.Decimal(14, 2)
  grossScheduledIncome Decimal?  @db.Decimal(14, 2)
  vacancyRate          Decimal?  @db.Decimal(5, 2)
  operatingExpenses    Json?
  netOperatingIncome   Decimal?  @db.Decimal(14, 2)
  capRate              Decimal?  @db.Decimal(6, 4)
  dscr                 Decimal?  @db.Decimal(6, 4)
  loanAmount           Decimal?  @db.Decimal(14, 2)
  interestRate         Decimal?  @db.Decimal(6, 4)
  amortizationYears    Int?
  annualDebtService    Decimal?  @db.Decimal(14, 2)
  loanMaturityDate     DateTime?
  rentRoll             Json?
  t12Financials        Json?
  businessPlan         Json?
  propertyManagerName  String?
  propertyManagerPhone String?
  propertyManagerEmail String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// Extension table — Tax Lien strategy
model DealTaxLien {
  id                      String    @id @default(cuid())
  dealId                  String    @unique
  deal                    Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  // Certificate details — required for ACTIVE deals, optional for LEAD/pre-bid
  certificateNumber       String?
  faceAmount              Decimal?  @db.Decimal(14, 2)
  interestRate            Decimal?  @db.Decimal(6, 4)
  penaltyRate             Decimal?  @db.Decimal(6, 4)
  issueDate               DateTime?
  saleDate                DateTime?
  // Lead / pre-bid tracking
  auctionDate             DateTime? // scheduled auction date
  maxBid                  Decimal?  @db.Decimal(14, 2) // max bid amount
  // Post-purchase tracking
  redemptionDeadline      DateTime?
  foreclosureEligibleDate DateTime?
  redemptionAmount        Decimal?  @db.Decimal(14, 2)
  redemptionDate          DateTime?
  isRedeemed              Boolean   @default(false)
  subsequentTaxesPaid     Decimal?  @db.Decimal(14, 2)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

// ============================================================
// EVENTS — Rule-derived milestones
// ============================================================

model Event {
  id            String      @id @default(cuid())
  dealId        String
  deal          Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  ruleId        String?
  eventType     EventType
  label         String
  dueDate       DateTime
  completedDate DateTime?
  status        EventStatus @default(PENDING)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tasks Task[]

  @@index([dealId])
  @@index([dueDate, status])
}

// ============================================================
// TASKS — Operational actions
// ============================================================

model Task {
  id           String     @id @default(cuid())
  dealId       String
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  eventId      String?
  event        Event?     @relation(fields: [eventId], references: [id])
  assignedToId String?
  assignedTo   User?      @relation(fields: [assignedToId], references: [id])
  tenantId     String
  taskType     TaskType
  title        String
  description  String?
  dueDate      DateTime?
  completedAt  DateTime?
  status       TaskStatus @default(OPEN)
  priority     Priority   @default(MEDIUM)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  checklistKey String? // set when created via checklist template; used for idempotency

  comments TaskComment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([assignedToId, status])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
  @@index([userId])
}

// ============================================================
// FINANCIALS
// ============================================================

model FinancialTransaction {
  id          String          @id @default(cuid())
  dealId      String
  deal        Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenantId    String
  type        TransactionType
  amount      Decimal         @db.Decimal(14, 2)
  date        DateTime
  description String?
  createdAt   DateTime        @default(now())

  @@index([dealId])
  @@index([tenantId])
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId        String?
  deal          Deal?        @relation(fields: [dealId], references: [id])
  propertyId    String?
  property      Property?    @relation(fields: [propertyId], references: [id])
  fileName      String
  fileSize      Int
  mimeType      String
  r2Key         String       @unique
  docType       DocumentType
  extractedData Json?
  uploadedAt    DateTime     @default(now())

  @@index([tenantId])
  @@index([dealId])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  dealId     String?
  deal       Deal?    @relation(fields: [dealId], references: [id])
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([dealId])
  @@index([entityType, entityId])
}

// ============================================================
// ENUMS
// ============================================================

enum PlanTier {
  STARTER
  PROFESSIONAL
  TEAM
  ENTERPRISE
}

enum ModuleTier {
  STANDARD
  PREMIUM
}

enum UserRole {
  OWNER
  ANALYST
  ATTORNEY
  ASSISTANT
  READ_ONLY
}

enum InvestmentType {
  LIEN
  DEED
  REDEEMABLE_DEED
}

enum StrategyType {
  TAX_LIEN
  TAX_DEED
  FORECLOSURE
  FIX_FLIP
  WHOLESALE
  BUY_HOLD
  LAND
  MULTIFAMILY
}

enum DealStatus {
  LEAD
  ACTIVE
  NOT_WON
  REDEEMED
  FORECLOSURE_INITIATED
  DEEDED
  SOLD
  CLOSED
  EXPIRED
}

/// Parcel access status. NONE means confirmed no legal/physical access; UNKNOWN means not yet researched.
enum LandNoteStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum LandDispositionStatus {
  LISTED
  UNDER_CONTRACT
  SOLD_CASH
  SOLD_TERMS
  RELISTED
}

enum LandAccess {
  ROAD
  EASEMENT
  LANDLOCKED
  NONE
  UNKNOWN
}

enum EventType {
  REDEMPTION_DEADLINE
  NOTICE_MAIL_BY
  PUBLICATION_START
  FORECLOSURE_ELIGIBLE
  FORECLOSURE_DEADLINE
  AUCTION_DATE
  DEED_ISSUED
  OPTION_EXPIRY
  PAYMENT_LATE
  INSPECTION_END
  CLOSING_DUE
  REHAB_DUE
  LISTING_TARGET
  LEASE_EXPIRY
  LOAN_MATURITY
  UNIT_LEASE_END
  HQS_INSPECTION
  RENT_INCREASE_WINDOW
  CUSTOM
}

enum EventStatus {
  PENDING
  COMPLETED
  OVERDUE
  SKIPPED
}

enum TaskType {
  SEND_NOTICE
  FILE_SUIT
  ORDER_TITLE_SEARCH
  RECORD_DOCUMENT
  PAY_SUBSEQUENT_TAXES
  REVIEW_REDEMPTION
  INITIATE_FORECLOSURE
  FOLLOW_UP
  CUSTOM
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TransactionType {
  PURCHASE
  SUBSEQUENT_TAX
  LEGAL_FEE
  TITLE_SEARCH
  RECORDING_FEE
  REDEMPTION_RECEIVED
  OTHER_INCOME
  OTHER_EXPENSE
  SALE_PROCEEDS
  RENT_RECEIVED
  NOTE_PAYMENT_RECEIVED
  REHAB_COST
  INSURANCE
  PROPERTY_TAX
  HOA_FEE
  MANAGEMENT_FEE
  LOAN_PAYMENT
}

enum DocumentType {
  LIEN_CERTIFICATE
  TAX_DEED
  PURCHASE_CONTRACT
  NOTICE_LETTER
  USPS_RECEIPT
  COURT_FILING
  TITLE_REPORT
  DEED
  LEASE
  OTHER
}

enum ContactType {
  OWNER
  ATTORNEY
  AGENT
  LENDER
  BUYER
  SELLER
  AGENCY
  OTHER
}
