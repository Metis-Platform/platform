# ============================================================
# Metis Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# App
APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon PostgreSQL)
# Get this from: https://neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/metis?sslmode=require

# Auth (Clerk)
# Get these from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# AI (Anthropic Claude API)
# Get this from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# File Storage (Cloudflare R2)
# Get these from: https://dash.cloudflare.com → R2 → your bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=metis-documents
NEXT_PUBLIC_R2_PUBLIC_URL=

# Email (Resend)
# Get this from: https://resend.com → API Keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Payments (Stripe)
# Get test keys from: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — two values needed:
#   Local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#              and copy the whsec_ it prints
#   Production: Stripe Dashboard → Developers → Webhooks → Add endpoint
#               URL: https://your-app.vercel.app/api/webhooks/stripe
#               Copy the Signing secret it generates
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — create these in Stripe Dashboard → Products
# Each plan needs one recurring price; copy the price_... ID here
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_TEAM=price_...

# Super-admin
# Comma-separated list of emails that can access /admin
SUPER_ADMIN_EMAILS=you@example.com

# Error monitoring (Sentry)
# Get DSN from: https://sentry.io → your project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Cron Jobs (Phase 1B)
# Generate a random secret: openssl rand -hex 32
# Add this same value to Vercel env vars so the cron job can authenticate.
CRON_SECRET=
